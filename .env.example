SECRET_KEY=change-me-generate-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,ninoliani.com,www.ninoliani.com
CSRF_TRUSTED_ORIGINS=https://ninoliani.com,https://www.ninoliani.com
SITE_URL=https://ninoliani.com

# Leave empty for local SQLite development.
# Production example:
# DATABASE_URL=postgres://ninoliani_user:change-me@127.0.0.1:5432/ninoliani
DATABASE_URL=
DATABASE_CONN_MAX_AGE=600

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
CONTACT_EMAIL_TO=

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
